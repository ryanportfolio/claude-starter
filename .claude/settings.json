{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git remote *)",
      "Bash(git diff *)",
      "Bash(git ls-tree *)",
      "Bash(mkdir *)",
      "Bash(head *)",
      "Bash(wc *)"
    ]
  }
}
